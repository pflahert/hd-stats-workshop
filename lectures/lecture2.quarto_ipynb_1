        "#| echo: true\n",
        "from scipy.stats import norm\n",
        "\n",
        "rng = np.random.default_rng(123)\n",
        "m, m1 = 5000, 200\n",
        "z_null = rng.normal(loc=0.2, scale=1.3, size=m - m1)  # empirical null ≠ N(0,1)\n",
        "z_alt = rng.normal(loc=3, scale=1, size=m1)\n",
        "z = np.concatenate([z_null, z_alt])\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(7, 4.5))\n",
        "ax.hist(z, bins=80, density=True, color=\"lightblue\", edgecolor=\"white\")\n",
        "x_grid = np.linspace(z.min(), z.max(), 300)\n",
        "ax.plot(x_grid, norm.pdf(x_grid, 0, 1), color=\"red\", linewidth=2, linestyle=\"--\",\n",
        "        label=\"Theoretical N(0,1)\")\n",
        "ax.plot(x_grid, norm.pdf(x_grid, 0.2, 1.3), color=\"blue\", linewidth=2,\n",
        "        label=\"Empirical null N(0.2, 1.3²)\")\n",
        "ax.set_title(\"Observed z-scores with empirical null\")\n",
        "ax.set_xlabel(\"z-score\")\n",
        "ax.legend(loc=\"upper right\")\n",
        "plt.tight_layout()\n",
        "plt.show()"

# Build outputs
_output/
_pdf/
.quarto/
_freeze/

# Environments / runtime
.venv
__pycache__/
*.pyc

# OS / editor cruft
.DS_Store
.idea/
.vscode/

# Claude Code internals (never commit)
.claude/

# Quarto intermediates (sometimes land in source dir)
*.quarto_ipynb
*.quarto_ipynb_1
*.quarto_ipynb_2
**/*.quarto_ipynb
notebooks/*_exec.ipynb

# LaTeX intermediates from `quarto render --to pdf`
*.aux
*.log
*.tex
*.toc
*.out

# Quarto figure caches and per-document asset folders that land next to source files
# (cover all backends: html, latex, pdf, beamer, revealjs)
**/*_files/

# Quarto-supplied asset library when individual files are rendered outside project
/site_libs/

# Rendered HTML/PDF that occasionally lands in source dirs from individual quarto render calls
/*.html
/*.pdf
assessments/*.html
assessments/*.pdf
lectures/*.html
lectures/*.pdf
syllabus/*.html
syllabus/*.pdf

# Pre-rendered PDFs that should not be committed at source root
syllabus/course-design.pdf

/.quarto/
